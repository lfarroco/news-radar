---
layout: main.njk
---

<div class="home">

	<!-- Compact banner -->
	<section class="home-hero">
		<p class="home-hero__banner">
			AI-curated software engineering headlines. <a href="https://github.com/lfarroco/news-radar">Open source on GitHub →</a>
		</p>
	</section>

	<!-- Latest stories -->
	<section class="home-featured">
		<h2 class="home-section-label">Latest Stories</h2>
		<div class="featured-grid">
			{% for article in latest %}
				{% if loop.index <= 9 %}
				<a class="featured-card" href="{{ article.url }}">
					<span class="featured-card__date">{{ article.formattedDate }}</span>
					<span class="featured-card__title">{{ article.title }}</span>
					{% if article.article_content %}
						<span class="featured-card__excerpt">
							{{ article.article_content.slice(0, 150) }}{% if article.article_content.length > 150 %}...{% endif %}
						</span>
					{% endif %}
					<span class="featured-card__cta">Read more →</span>
				</a>
				{% endif %}
			{% endfor %}
		</div>
	</section>

	<!-- Topics grid -->
	<section class="home-topics">
		<h2 class="home-section-label">Browse by Topic</h2>
		<div class="topics-grid">
			{% for topic in topics %}
				<div class="topic-card">
					<div class="topic-card__header">
						<span class="topic-card__name">{{ topic.name }}</span>
						<div class="topic-card__actions">
							<a class="topic-card__all" href="/topics/{{ topic.slug }}">All →</a>
							<a class="rss-icon-link" href="{{ topic.feedUrl }}" title="Subscribe to {{ topic.name }} RSS" aria-label="Subscribe to {{ topic.name }} RSS">
								<svg viewBox="0 0 24 24" role="presentation" focusable="false" aria-hidden="true">
									<circle cx="5" cy="19" r="2"></circle>
									<path d="M4 11a9 9 0 0 1 9 9"></path>
									<path d="M4 4a16 16 0 0 1 16 16"></path>
								</svg>
							</a>
						</div>
					</div>
					<ul class="topic-card__list">
						{% for article in topic.articles %}
							<li class="topic-card__item">
								<a href="{{ article.url }}">{{ article.title }}</a>
								<time class="topic-card__time">{{ article.formattedDate }}</time>
							</li>
						{% endfor %}
					</ul>
				</div>
			{% endfor %}
		</div>
	</section>

</div>
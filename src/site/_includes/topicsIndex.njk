---
layout: main.njk
---

<section class="topics-index">
	<header class="topics-index__header">
		<h1 class="mb-0">Topics</h1>
		<p class="topics-index__sub">Explore news by language, framework, and ecosystem.</p>
	</header>

	<div class="topics-index__grid">
		{% for topic in topics %}
			<div class="topics-index__card">
				<a class="topics-index__open" href="{{ topic.url }}">
					<span class="topics-index__name">{{ topic.icon or '📰' }} {{ topic.name }}</span>
					<span class="topics-index__count">{{ topic.article_count }} articles</span>
				</a>
				<a class="rss-icon-link" href="{{ topic.feedUrl or '/topics/' ~ topic.slug ~ '/feed.xml' }}" title="Subscribe to {{ topic.name }} RSS" aria-label="Subscribe to {{ topic.name }} RSS">
					<svg viewBox="0 0 24 24" role="presentation" focusable="false" aria-hidden="true">
						<circle cx="5" cy="19" r="2"></circle>
						<path d="M4 11a9 9 0 0 1 9 9"></path>
						<path d="M4 4a16 16 0 0 1 16 16"></path>
					</svg>
				</a>
			</div>
		{% endfor %}
	</div>
</section>
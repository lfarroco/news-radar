---
layout: main.njk
---

<article class="card mt-2">
	<div class="card-header">
		<h1 class="mb-0">{{ title }}</h1>
		<div>
			<small>{{formattedDate}}</small>
		</div>

	</div>
	<div class="card-body">
		<div class="article-content">
			{{ content | md | safe }}
		</div>

		{% if references and references.length %}
		<section class="article-references">
			<h2 class="article-references__title">References</h2>
			<ul class="article-references__list">
				{% for ref in references %}
					<li>
						<a href="{{ ref.url }}" target="_blank" rel="noopener noreferrer">{{ ref.label }}</a>
					</li>
				{% endfor %}
			</ul>
		</section>
		{% endif %}
	</div>
</article>